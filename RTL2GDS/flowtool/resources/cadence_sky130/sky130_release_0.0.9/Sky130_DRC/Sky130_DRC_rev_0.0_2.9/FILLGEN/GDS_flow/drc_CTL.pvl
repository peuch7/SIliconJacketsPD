text_depth -primary;
virtual_connect -colon no;
virtual_connect -semicolon_as_colon yes;
virtual_connect -noname;
virtual_connect -report no;
virtual_connect -depth -primary;
report_summary -drc "CELLNAME.sum" -replace;
max_results -drc -all;
results_db -drc "CELLNAME.drc.ascii" -ascii;
keep_layers -yes;
abort_on_layout_error yes;
layout_format gdsii;
layout_path "./CELLNAME.wFill.gds.gz";
