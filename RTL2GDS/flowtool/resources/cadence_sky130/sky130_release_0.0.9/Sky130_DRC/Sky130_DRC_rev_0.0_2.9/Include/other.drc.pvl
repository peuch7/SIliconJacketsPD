//////////////////////////////////////////////////////////////////
//	  Other Rules		  				//
// Version 0.0_2.9  June 25, 2025				//
//////////////////////////////////////////////////////////////////
//
// Other rules:
//	contacts and vias must be covered by metals
//	res layers must fit exactly inside drawing layers
//	metals cannot be drawn over blockage layers
//
// These are generally rules that apply to multiple layers
//
//////////////////////////////////////////////////////////////////


//////////////////////////////////////////////////////////////////
// Contacts and Vias

// licon inside LI and (poly or diff or tap) covered by rules licon.4a & licon.4b
// poly licon inside npc is covered by rule licon.18

#IFNDEF SRAM
  rule mcon.cover.1 {
	caption "CDR: mcon must be inside li"
	NOT mcon li1 ;
  }
#ENDIF

#IFDEF SRAM
  rule mcon.cover.1 {
	caption "CDR: mcon must be inside li"
	NOT mcon_notcore li1 ;
  }
  rule mcon.cover.1_SRAM {
	caption "mcon insice areaid.ce must overlap li"
	select -outside mcon_core li1 ;

  }
  rule mcon.WARNING {
	caption "CORE WARNING: alternate mcon.cover.1 rule used in areaid.ce regions "
	caption "CORE WARNING: real mcon.cover.1 errors may be missed "
	extent_drawn areaid.ce ; ;
  }
#ENDIF


rule mcon.cover.2 {
	caption "mcon must be inside met1"
	NOT mcon met1 ;
}
rule via1.cover.1 {
	caption "via1 must be inside met1"
	NOT via1 met1 ;
}
rule via1.cover.2 {
	caption "via1 must be inside met2"
	NOT via1 met2 ;
}
rule via2.cover.1 {
	caption "via2 must be inside met2"
	NOT via2 met2 ;
}
rule via2.cover.2 {
	caption "via2 must be inside met3"
	NOT via2 met3 ;
}
rule via3.cover.1 {
	caption "via3 must be inside met3"
	NOT via3 met3 ;
}
rule via3.cover.2 {
	caption "via3 must be inside met4"
	NOT via3 met4 ;
}
rule via4.cover.1 {
	caption "via4 must be inside met4"
	NOT via4 met4 ;
}
rule via4.cover.2 {
	caption "via4 must be inside met5"
	NOT via4 met5 ;
}


//////////////////////////////////////////////////////////////////
//  Res layers 

#IFNDEF NOWARNINGS

  select -cut -not diff_res li1 -outputlayer diffres_maybe
  NOT diff_dg diffres_maybe  diff_dg_not_res ;

//select -touch -not diffres_maybe diff_dg_not_res -eq 2 -outputlayer diffres_not_touch_2

  rule difftap.res { 
  	caption "WARNING: diff res must fit exactly inside diff drawing"
  	select -touch -not diffres_maybe diff_dg_not_res -eq 2 ;
  	select -cut diff_res diff ;
  }

  select -cut -not li1_res li1 -outputlayer lires_maybe
  NOT li_dg lires_maybe  li_dg_not_res

//select -touch -not lires_maybe li_dg_not_res -eq 2 -outputlayer lires_not_touch_2

  rule li.res { 
  	caption "WARNING: li res must fit exactly inside li drawing"
  	select -touch -not lires_maybe li_dg_not_res -eq 2 ;
  	select -cut li1_res li1 ;
  }

  select -cut -not met1_res li1 -outputlayer met1res_maybe
  NOT m1_dg met1res_maybe  m1_dg_not_res ;

  rule m1.res { 
  	caption "WARNING: met1 res must fit exactly inside met1 drawing"
  	select -touch -not met1res_maybe m1_dg_not_res -eq 2 ;
  	select -cut met1_res met1 ;
  }

  select -cut -not met2_res li1 -outputlayer met2res_maybe
  NOT m2_dg met2res_maybe  m2_dg_not_res ;

  rule m2.res { 
  	caption "WARNING: met2 res must fit exactly inside met2 drawing"
  	select -touch -not met2res_maybe m2_dg_not_res -eq 2 ;
  	select -cut met2_res met2 ;
  }

  select -cut -not met3_res li1 -outputlayer met3res_maybe
  NOT m3_dg met3res_maybe  m3_dg_not_res ;

  rule m3.res { 
  	caption "WARNING: met3 res must fit exactly inside met3 drawing"
  	select -touch -not met3res_maybe m3_dg_not_res -eq 2 ;
  	select -cut met3_res met3 ;
  }

  select -cut -not met4_res li1 -outputlayer met4res_maybe
  NOT m4_dg met4res_maybe  m4_dg_not_res ;

  rule m4.res { 
  	caption "WARNING: met4 res must fit exactly inside met4 drawing"
  	select -touch -not met4res_maybe m4_dg_not_res -eq 2 ;
  	select -cut met4_res met4 ;
  }

  select -cut -not met5_res li1 -outputlayer met5res_maybe
  NOT m5_dg met5res_maybe  m5_dg_not_res ;

  rule m5.res { 
  	caption "WARNING: met5 res must fit exactly inside met5 drawing"
  	select -touch -not met5res_maybe m5_dg_not_res -eq 2 ;
  	select -cut met5_res met5 ;
  }

#ENDIF	// #ifndef NOWARNINGS


//////////////////////////////////////////////////////////////////
//  Blocking layers 

rule li.block.1 {
 	caption "li cannot overlap li blockage"
	AND li1 li1_block ;
}
rule m1.block.1 {
	caption "met1 cannot overlap met1 blockage"
	AND met1 met1_block ;
}
rule m2.block.1 {
	caption "met2 cannot overlap met2 blockage"
	AND met2 met2_block ;
}
rule m3.block.1 {
	caption "met3 cannot overlap met3 blockage"
	AND met3 met3_block ;
}
rule m4.block.1 {
	caption "met4 cannot overlap met4 blockage"
	AND met4 met4_block ;
}
rule m5.block.1 {
 	caption "met5 cannot overlap met5 blockage"
	AND met5 met5_block ;
}

rule li.block.2 {
	caption "Min spacing of li to li blockage: 0.17 um"
	exte li1 li1_block -lt 0.17 -single_point -output region 
}
rule m1.block.2 {
	caption "Min spacing of met1 to met1 blockage: 0.14 um"
	exte met1 met1_block -lt 0.14 -single_point -output region 
}
rule m2.block.2 {
	caption "Min spacing of met2 to met2 blockage: 0.14 um"
	exte met2 met2_block -lt 0.14 -single_point -output region 
}
rule m3.block.2 {
	caption "Min spacing of met3 to met3 blockage: 0.30 um"
	exte met3 met3_block -lt 0.30 -single_point -output region 
}
rule m4.block.2 {
	caption "Min spacing of met4 to met4 blockage: 0.30 um"
	exte met4 met4_block -lt 0.30 -single_point -output region 
}
rule m5.block.2 {
	caption "Min spacing of met5 to met5 blockage: 1.60 um"
	exte met5 met5_block -lt 1.60 -single_point -output region 
}

