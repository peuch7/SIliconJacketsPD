//      layer_def cmm5_waffle_drop	1264	
//      layer_map 117 -datatype     4 	1264	//cmm5,waffle drop,117:4

#IFNDEF NOWARNINGS

// diff
  layer_def cfom_fill 9001
  layer_map 22 -datatype 99 9001 // old cfom fill


  rule "diff.fill.1" {
	caption "WARNING: cfom/fill (GDS 22:99) is not supported. Use diff/fill (GDS 65:99)"
	copy cfom_fill ;
  }
  rule "diff.fill.2" {
	caption "WARNING: cfom/waffleDrop (GDS 22:24) is not supported. Use diff/fill_block (GDS 65:98)"
	copy cfom_waffle_drop ;
  } 

// poly
  layer_def cp1m_fill 9091
  layer_map 28 -datatype 28 9091 // old poly fill

  rule "poly.fill.1" {
	caption "WARNING: cp1m/fill (GDS 28:28) is not supported. Use poly/fill (GDS 66:99)"
	copy cp1m_fill ;
  }

  rule "poly.fill.2" {
	caption "WARNING: cp1m/waffleDrop (GDS 33:24) is not supported. Use poly/fill_block (GDS 66:98)"
	copy cp1m_waffle_drop ;
  }

  layer_def cli1m_fill 9111
  layer_map 56 -datatype 28 9111 // old li fill

  rule "li.fill.1" {
	caption "WARNING: cli1m/fill (GDS 56:28) is not supported. Use li/fill (GDS 67:99)"
	copy cli1m_fill
  }

  layer_def cmm1_fill 9002
  layer_map 36 -datatype 28 9002 // old cmm1 fill

  rule "m1.fill.1" {
	caption "WARNING: cmm1/fill (GDS 36:28) is not supported. Use met1/fill (GDS 68:99)"
	copy cmm1_fill
  }

  rule "m1.fill.2" {
	caption "WARNING: cmm1/waffleDrop (GDS 62:24) is not supported. Use met1/fill_block (GDS 68:98)"
	copy cmm1_waffle_drop
  }

  layer_def cmm2_fill 9003
  layer_map 41 -datatype 28 9003 // old cmm2 fill

  rule "m2.fill.1" {
	caption "WARNING: cmm2/fill (GDS 41:28) is not supported. Use met2/fill (GDS 69:99)"
	copy cmm2_fill
  }

  rule "m2.fill.2" {
	caption "WARNING: cmm2/waffleDrop (GDS 105:52) is not supported. Use met2/fill_block (GDS 69:98)"
	copy cmm2_waffle_drop
  }


  layer_def cmm3_fill 9004
  layer_map 34 -datatype 28 9004 // old cmm3 fill

  rule "m3.fill.1" {
	caption "WARNING: cmm3/fill (GDS 34:28) is not supported. Use met3/fill (GDS 70:99)"
	copy cmm3_fill
  }

  rule "m3.fill.2" {
	caption "WARNING: cmm3/waffleDrop (GDS 107:52) is not supported. Use met3/fill_block (GDS 70:98)"
	copy cmm3_waffle_drop
  }

  layer_def cmm4_fill 9005
  layer_map 51 -datatype 28 9005 // old cmm4 fill

  rule "m4.fill.1" {
	caption "WARNING: cmm4/fill (GDS 51:28) is not supported. Use met4/fill (GDS 71:99)"
	copy cmm4_fill
  }

  rule "m4.fill.2" {
	caption "WARNING: cmm4/waffleDrop (GDS 112:4) is not supported. Use met4/fill_block (GDS 71:98)"
	copy cmm4_waffle_drop
  }

  layer_def cmm5_fill 9006
  layer_map 59 -datatype 28 9006 // old cmm5 fill

  rule "m5.fill.1" {
	caption "WARNING: cmm5/fill (GDS 59:28)) is not supported. Use met5/fill (GDS 72:99)"
