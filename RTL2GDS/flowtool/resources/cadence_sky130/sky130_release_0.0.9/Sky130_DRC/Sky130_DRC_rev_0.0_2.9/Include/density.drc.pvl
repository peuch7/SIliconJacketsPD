}

rule "m2.global.max" {
	caption "CDR: Max global density of met2 inside seal ring: 62%"
	density m2_layers -gt 0.62 -inside_of layer fill_extent_not_SEALID -rdb m2_global_high.rdb
}

rule "m3.global.min" {
	caption "CDR: Min global density of met3 inside seal ring: 33%"
	density m3_layers -lt 0.33 -inside_of layer fill_extent_not_SEALID -rdb m3_global_low.rdb
}

rule "m3.global.max" {
	caption "CDR: Max global density of met3 inside seal ring: 62%"
	density m3_layers -gt 0.62 -inside_of layer fill_extent_not_SEALID -rdb m3_global_high.rdb
}

rule "m4.global.min" {
	caption "CDR: Min global density of met4 inside seal ring: 33%"
	density m4_layers -lt 0.33 -inside_of layer fill_extent_not_SEALID -rdb m4_global_low.rdb
}

rule "m4.global.max" {
	caption "CDR: Max global density of met4 inside seal ring: 62%"
	density m4_layers -gt 0.62 -inside_of layer fill_extent_not_SEALID -rdb m4_global_high.rdb
}

rule "m5.global.min" {
	caption "CDR: Min global density of met5 inside seal ring: 43%"
	density m5_layers -lt 0.33 -inside_of layer fill_extent_not_SEALID -rdb m5_global_low.rdb
}

rule "m5.global.max" {
	caption "CDR: Max global density of met5 inside seal ring: 78%"
	density m5_layers -gt 0.62 -inside_of layer fill_extent_not_SEALID -rdb m5_global_high.rdb
}




