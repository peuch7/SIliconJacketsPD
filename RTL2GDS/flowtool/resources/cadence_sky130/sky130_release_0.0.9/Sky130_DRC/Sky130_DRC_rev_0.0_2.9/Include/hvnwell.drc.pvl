// spacing of 1.8v nwell found in nwell.drc.pvl
// spacing of 1.8v nwell to other voltages found in nwell.drc.pvl 

// NOTE:  spacings with LV nwell are in nwell.drc.pvl

rule "hvnwell.8.hv" {
	caption "Min space/notch of HV_nwell: 1.27"
	exte nwell_hv -lt 1.27 -abut -lt 90 -single_point -output region
}
rule "hvnwell.8.hv_vhv" {
	caption "Min space of HV_nwell to VHV_nwell: 2.0"
	exte nwell_hv nwell_vhv -lt 2.0 -abut -lt 90 -single_point -output region
}
rule "hvnwell.8.hv_uhv" {
	caption "Min space of HV_nwell to UHV_nwell: 2.5"
	exte nwell_hv nwell_uhv -lt 2.5 -abut -lt 90 -single_point -output region
}
rule "hvnwell.8.vhv" {
	caption "Min space/notch of VHV_nwell: 2.0"
	exte nwell_vhv -lt 2.0 -abut -lt 90 -single_point -output region
}
rule "hvnwell.8.vhv_uhv" {
	caption "Min space of VHV_nwell to UHV_nwell: 2.5"
	exte nwell_vhv nwell_uhv -lt 2.5 -abut -lt 90 -single_point -output region
}
rule "hvnwell.8.uvh" {
	caption "Min space/notch of UHV_nwell: 2.5"
	exte nwell_uhv -lt 2.5 -abut -lt 90 -single_point -output region
}


select -cut nwell hvi -outputlayer nwell_ovlp_hvi

rule hvnwell.9 {
	caption "(Nwell overlapping hvi) must be enclosed by hvi"
	NOT nwell_ovlp_hvi hvi ;
}

