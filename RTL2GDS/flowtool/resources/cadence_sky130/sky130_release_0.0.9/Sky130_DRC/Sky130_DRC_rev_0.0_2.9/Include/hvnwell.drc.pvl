//////////////////////////////////////////////////////////////////
//	  hvnwell rules		   //
// Version 0.0_2.9  June 25, 2025				//
// DRM Section 5.7.38			   //
//////////////////////////////////////////////////////////////////

// hvi == v5 ; vhvi == v12 ; uhvi == v20

// multiple minimum spacings for nwell regions with different voltages

//  derive nwell voltage layers 

// nwell_lv	-- 1.8v, low voltage nwell (not v5, v12, v20)
// nwell_hv 	-- 5v, high voltage nwell (v5)
// nwell_vhv 	-- 12v, very high voltage nwell (v12)
// nwell_uhv 	-- 20v, ltra high voltage nwell (v20)

// all_hvi	-- OR of all high voltage markers (hvi, vhvi, uhvi)

OR hvi vhvi uhvi -outputlayer all_hvi

select -interact nwell uhvi -outputlayer nwell_uhvi
stamp nwell_uhvi nwell -outputlayer nwell_uhv

not nwell nwell_uhv -outputlayer nw_not_uvh
select -interact nw_not_uvh vhvi -outputlayer nwell_vhvi
stamp nwell_vhvi nwell -outputlayer nwell_vhv 

not nwell ( or nwell_uhv nwell_vhv ) -outputlayer nw_not_vhv_or_uhv
select -interact nw_not_vhv_or_uhv hvi -outputlayer nwell_hvi
stamp nwell_hvi nwell -outputlayer nwell_hv

// areaid		lv_net		81	66
//layer_def lv_net 1299
//layer_map 81 -datatype 66 1284 // areaid:lvnet
// ** lv_net is NOT in the sky130_fd_pr_main library

select -interact -not nwell all_hvi -outputlayer nwell_lvi
stamp nwell_lvi nwell -outputlayer nwell_lv


