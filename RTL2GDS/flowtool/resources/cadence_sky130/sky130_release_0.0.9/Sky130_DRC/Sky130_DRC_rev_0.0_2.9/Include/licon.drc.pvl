// split up rule licon.4 to make missing layer obvious
// also, change to NOT as licon must be completely covered

// If SRAM is not defined, run the usual rules, else run the SRAM versions

#IFNDEF SRAM
  rule licon.4a {
	caption "licon must be inside li"
	not licon li1 ;

  }
  rule licon.4b {
	caption "licon must be inside (poly or diff or tap)"
	not licon (or poly diff tap) ;
  }
#ENDIF

#IFDEF SRAM
  rule licon.4a {
	caption "licon must be inside li"
	not licon_notcore li1 ;
  }
  rule licon.4b {
	caption "licon must be inside (poly or diff or tap)"
	not licon_notcore (or poly diff tap) ;
  }
  rule licon.4a_SRAM {
	caption "licon inside areaid.ce must overlap li"
	select -outside licon_core li1 ;
  }
  rule licon.4b_SRAM {
	caption "licon inside areaid.ce must overlap (poly or diff or tap)"
	select -outside licon_core (or poly diff tap) ;
  }
  rule licon.WARNING {
	caption "CORE WARNING: alternate licon.4a & licon.4b rules used in areaid.ce regions "
	caption "CORE WARNING: real licon.4a & licon.4b errors may be missed "
	extent_drawn areaid.ce ;
  }
#ENDIF


//////////////////////////////////////////////////////////////////
// licon ENC rules

rule licon.5a {
	caption "Min enclosure of licon outside areaid.ce by diff (not tap): 0.040 um"
	enc licon_notcore diff_all -lt 0.040 -output region
	edge_select licon_notcore diff ;
}

rule licon.5c {
	caption "Min enclosure of licon outside areaid.ce by diff on one of two adjacent sides: 0.060 um"
	rect_enc licon_notcore diff_in -good 0.060 0.000 0.060 0.000 
}

select -with_edge tap ( edge_boolean -coincident_only -outside tap diff ) -outputlayer non_isolated_tap
not tap non_isolated_tap -outputlayer isolated_tap

rule licon.7 {
	caption "Min enclosure of licon outside areaid.ce by one of two adjacent sides of isolated tap: 0.120 um"
	rect_enc licon_notcore isolated_tap -good 0.120 0.000 0.120 0.000 
}

rule licon.8 {
	caption "Min enclosure of poly_licon outside areaid.ce by poly: 0.050 um"
	enc poly_licon_notcore poly -lt 0.050 -output region
	edge_select poly_licon_notcore poly ;
}

rule licon.8a {
	caption "Min enclosure of poly_licon outside areaid.ce by poly on one of two adjacent sides: 0.080 um"
	rect_enc poly_licon_notcore poly -good 0.080 0.000 0.080 0.000
}

rule licon.15 {
	caption "poly_licon outside areaid.ce must be enclosed by npc by: 0.100 um"
	enc poly_licon_notcore npc -lt 0.100 -output region ;
	edge_select poly_licon_notcore npc ;
}

rule licon.15b {
	caption "poly_licon inside areaid.ce must be enclosed by npc by: 0.045 um"
	enc poly_licon_core npc -lt 0.045 -output region ;
	edge_select poly_licon_core npc ;
}

//////////////////////////////////////////////////////////////////



rule licon.6 {
	caption "licon cannot straddle tap"
	select -cut licon (or ptap_actual ntap_actual)
}


//rule licon.10 {
//	caption "Spacing of licon on (tap AND (nwell NOT hvi)) to Var_channel: 0.250 um"
//	caption "   TBA   "
//}

rule licon.11 {
	caption "Spacing of licon on diff or tap to poly on diff: 0.055 um"
	caption "(except for all FETs inside areaid.sc"
	caption "and except s8spf-10r flow for 0.5um phv inside cell names s8fs_gwdlvx4,"
	caption "s8fs_gwdlvx8, s8fs_hvrsw_x4, s8fs_hvrsw8, s8fs_hvrsw264,"
	caption "and s8fs_hvrsw520 and for 0.15um nshort inside cell names s8fs_rdecdrv,"
	caption "s8fs_rdec8, s8fs_rdec32, s8fs_rdec264, s8fs_rdec520)"
	caption "NOTE: exceptions have NOT been considered, there may be false errors"
	not gate areaid.sc -outputlayer licon.11_a
	or diff tap -outputlayer licon.11_b
//	and licon licon.11_b -outputlayer licon.11_c
	and licon_notcore licon.11_b -outputlayer licon.11_c
	exte licon.11_a licon.11_c -lt 0.055 -output region
}

rule licon.11a {
	caption "CDR: Spacing of licon on diff or tap to poly on diff: 0.050 um"
	caption "(for all FETs inside areaid.sc except 0.15um phighvt)"
	caption "NOTE: exceptions have NOT been considered, there may be false errors"
	and gate areaid.sc -outputlayer licon.11a_a
	or diff tap -outputlayer licon.11a_b
	and licon_notcore licon.11a_b -outputlayer licon.11a_c
	and licon.11a_a diff -outputlayer licon.11a_d
	exte licon.11a_c licon.11a_d -lt 0.050 -output region
}

//rule licon.11b {
//	caption "Spacing of licon on diff or tap to poly on diff (for 0.15um phighvt inside areaid.sc): 0.050 um"
//	caption "	TBA   "
//}

//rule licon.11c {
//	caption "Spacing of licon on diff or tap to poly on diff: 0.040 um"
//	caption "(for 0.5um phv inside cell names s8fs_gwdlvx4, s8fs_gwdlvx8,"
//	caption "s8fs_hvrsw_x4, s8fs_hvrsw8, s8fs_hvrsw264, and s8fs_hvrsw520)"
//	caption "   TBA   "
//}

//rule licon.11d {
//	caption "Spacing of licon on diff or tap to poly on diff: 0.045 um"
//	caption "(for 0.15um nshort inside cell names s8fs_rdecdrv, s8fs_rdec8,"
//	caption "s8fs_rdec32, s8fs_rdec264, s8fs_rdec520)"
//	caption "	TBA	"
//}
   
#IFDEF NC
  not diff gate -outputlayer diff_not_gate
  select -enclose -not diff_not_gate licon -outputlayer diff_no_licon
  edge_select -coincident_only diff_no_licon gate -outputlayer diff_no_licon_edge
  edge_length diff_no_licon_edge -gt 5.7 -outputlayer diff_edge57_no_licon
	  
// This rule is Guideline only (NC)
  rule licon.12 {
	  caption "GUIDELINE: Max SD width without licon: 5.700 um"
	  copy diff_edge57_no_licon ; 
  }
#ENDIF  // NC

rule licon.13 {
	caption "CDR: Spacing (no overlap) of NPC to licon on diff or tap: 0.090 um"
	or diff tap -outputlayer licon.13_a
	and licon licon.13_a -outputlayer licon.13_b
	exte npc licon.13_b -lt 0.090 -overlap -output region
}



//rule licon.16 {
//}

rule licon.17 {
	caption "Licons may not overlap both poly and (diff or tap)"
	select -cut licon poly -outputlayer licon.17_a
	or diff tap -outputlayer licon.17_b
	select -cut licon.17_a licon.17_b ;
	AND licon (AND diff poly) ;
}

rule licon.18 {
	caption "npc must enclose poly_licon"
	not poly_licon npc
}

//rule licon.19 {
//	caption "poly of the HV varactor must not interact with licon"
//	caption "	TBA   "
//} 

rule licon.20 {
	caption "Every tap must enclose at least 1 licon (except in uhvi)"
	not tap areaid.ce -outputlayer tap_not_core
	or tap_not_core ( select -cut tap areaid.ce ) -outputlayer npcon_tap
	not ( select -enclose -not ( not npcon_tap diff_fill ) licon ) uhvi
}

rule licon.21 {
	caption "psdm overlapping (poly and licon) is prohibited inside areaid.ce"
	and (and poly_licon_core psdm) areaid.ce ;
}

#IFNDEF NOWARNINGS
  rule licon.core {
	caption "WARNING: licon straddling areaid.ce (CORE)"
	not (select -cut licon areaid.ce) areaid.ce
  }
#ENDIF	// ifndef NOWARNINGS

