//////////////////////////////////////////////////////////////////
// licon filtering

// filter licon by seal ring, precision resistor
// Assuming seal ring takes precedence

// licon must be completely inside the corresponding layer
// otherwise, apply the most stringent rule (0.17 x 0.17)

// Precision resistor is formed from poly, poly res, (or rpm urpm)

// licon in / not in seal ring 
// SEALID only applies to rule licon.3
select -inside licon SEALID -outputlayer licon_insideSR
NOT	licon licon_insideSR licon_outsideSR ;

// licon from / not from precision resistor
select -interact -not licon (OR rpm urpm) -outputlayer licon_not_precR  // licon not precision resistor
NOT licon licon_not_precR licon_precR				 	// licon in precision resistor

// licon in / not in CORE
select -interact licon areaid.ce -outputlayer licon_core
NOT licon licon_core -outputlayer licon_notcore

rect_chk licon_outsideSR -aspect -eq 1 -outputlayer licon_square


AND poly licon -outputlayer poly_licon
AND poly licon_notcore -outputlayer poly_licon_notcore
AND poly licon_core -outputlayer poly_licon_core

//rpm_urpm alread defined: OR rpm urpm


//////////////////////////////////////////////////////////////////
// licon size rules


// update wording to use "bar licon" instead of prec_resistor

rule licon.1 {
	caption "CDR: Min and max L and W of licon, except for bar licon: 0.170 um"
	rect_chk -not licon_not_precR -eq 0.170 -by -eq 0.170 -orthogonal_only 
}

// licon_precR is found if licon is in (rpm OR urpm)
// maybe update this such that if 0.17x0.17 is found in (rpm OR urpm), change the caption

rect_chk licon_precR -eq 0.17 -by -eq 0.17 -outputlayer licon_017_in_prec

rule licon.1a {
	caption "licon sized 0.17 um X 0.17 um found in precision resistor -- "
	caption "licon inside (rpm OR urpm) should be 0.19 um X 2.0 um bar licon " 
	copy licon_017_in_prec ;
}
rule licon.1b {
	caption "CDR: Min and max width of bar licon == 0.190 um"
	rect_chk -not (not licon_precR licon_017_in_prec) -eq 0.19 ;
}
rule licon.1c {
	caption "CDR: Min and max length of bar licon == 2.000 um"
	rect_chk -not (not licon_precR licon_017_in_prec) -eq 2.0 ;
}


rule licon.3 {
	caption "Only min. square licons are allowed except die seal ring where licons are (licon CD)*L: 0.170 um"
	caption "  this seal ring licon does not have width = 0.17 um "
	rect_chk -not licon_insideSR -eq 0.17
}

//////////////////////////////////////////////////////////////////

//////////////////////////////////////////////////////////////////
// licon to licon spacing rules

// need to exclude CORE licon
rule licon.2 {
	caption "CDR: Min spacing of licon to licon: 0.17 um"
	caption "  For non-bar licon outside of areaid.ce "
	exte licon_notcore -lt 0.170 -single_point -output region
}
rule licon.2a {
	caption "CDR: Min spacing of licon to licon: 0.165 um"
	caption "  For non-bar licon inside of areaid.ce "
	exte licon_core -lt 0.165 -single_point -output region
}

rect_chk licon -eq 0.19 -by -eq 2.0 -outputlayer licon_bar 

rule "licon.2b" {
	caption "Min end-to-end space of bar licon: 0.35 um"
	edge_length licon_bar -lt 2.0 -outputlayer licon_end
	exte licon_end -lt 0.35 -abut -lt 90 -output region
}
rule "licon.2c" {
	caption "Min side-to-side spacing of bar licon: 0.51 um"
	edge_length licon_bar -gt 0.19 -outputlayer licon_side
	exte licon_side -lt 0.510 -abut -lt 90 -output region
}
rule "licon.2d" {
	caption "Min space from bar licon to square licon: 0.51 um"
	exte licon_square licon_bar -lt 0.510 -abut -lt 90 -output region -single_point
}


//////////////////////////////////////////////////////////////////
// Other licon spacing rules

// licon.5b has no CORE equivalent
rule licon.5b {
	caption "CDR: Min space between tap_licon outside areaid.ce and diff-abutting tap edge: 0.060 um"
	and tap licon_notcore -outputlayer licon.5b
	exte licon.5b ( edge_boolean -coincident_only -outside diff tap ) -lt 0.06 -abut -lt 90 -output region
}

// licon.9 has no CORE equivalent
// No need to check bar-licon since these will fail bar-licon spacing rules
rule licon.9 {
	caption "CDR: Min spacing, no overlap, between poly_licon outside areaid.ce and psdm: 0.110 um"
	select -outside poly_licon_notcore rpm_urpm -outputlayer licon.9_a
	exte licon.9_a psdm -lt 0.110 -overlap -output region
	and licon.9_a psdm ;
}

rule licon.14 {
	caption "Min spacing of poly_licon outside areaid.ce to diff or tap: 0.190 um"
	or diff tap -outputlayer licon.14_2
	exte poly_licon_notcore licon.14_2 -lt 0.190 -output region
}
rule licon.14a {
	caption "Min spacing of poly_licon inside areaid.ce to diff or tap: 0.130 um"
	or diff tap -outputlayer licon.14a_2
	exte poly_licon_core licon.14a_2 -lt 0.190 -output region
}


//////////////////////////////////////////////////////////////////

//rule licon 2b {
//	caption "Min spacing between two slotted_licon (when the both the edges are 0.19um in length): 0.350 um"
//	caption "	TBA   "
//}

//rule licon.2c {
//	caption "Min spacing between two slotted_licon (except for rule licon.2b): 0.510 um"
//	caption "	TBA   "
//}

//rule licon.2d {
//	caption "Min spacing between a slotted_licon and 0.17um square licon: 0.510 um"
//	caption "	TBA   "
